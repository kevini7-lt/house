<view class="page">
  <view class="header card">
    <view class="title">{{building.name || '房间列表'}}</view>
    <view class="subtitle">{{building.address || '展示楼栋下的全部房间'}}</view>
  </view>

  <view wx:if="{{loading}}" class="empty">正在加载房间...</view>
  <view wx:elif="{{rooms.length === 0}}" class="empty">暂无房间数据</view>
  <view wx:else>
    <view class="room-card card" wx:for="{{rooms}}" wx:key="id">
      <view class="room-top">
        <view>
          <view class="room-title">{{item.communityName || ''}} {{item.buildingName || ''}} {{item.number || ''}} 室</view>
          <view class="room-address">{{item.address || '暂无地址'}}</view>
        </view>
        <view class="rent">¥{{item.rent || 0}}</view>
      </view>

      <view class="room-info">
        <view>
          <text class="info-label">状态</text>
          <text class="info-value status-{{item.status === '已租' ? 'rented' : 'free'}}">{{item.status || '可入住'}}</text>
        </view>
        <view>
          <text class="info-label">户型</text>
          <text class="info-value">{{item.layout || '单间'}}</text>
        </view>
        <view>
          <text class="info-label">联系人</text>
          <text class="info-value">{{item.contactName || '暂无'}}</text>
        </view>
      </view>

      <view class="tags">
        <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
      </view>

      <button class="call-btn" bindtap="callOwner" data-phone="{{item.phone}}">联系房东 {{item.phone || ''}}</button>
    </view>
  </view>
</view>
