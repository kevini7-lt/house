<view class="page">
  <view class="header card">
    <view class="title">{{building.buildingNo || building.name || '房间列表'}}</view>
    <view class="subtitle">展示楼栋下的全部房间</view>
  </view>

  <view wx:if="{{loading}}" class="empty">正在加载房间...</view>
  <view wx:elif="{{rooms.length === 0}}" class="empty">暂无房间数据</view>
  <view wx:else>
    <room-card
      wx:for="{{rooms}}"
      wx:key="roomId"
      room="{{item}}"
      bindtap="goRoomDetail"
    />
  </view>
</view>
