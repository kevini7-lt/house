.header {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.room-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
}

.room-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.room-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.room-address {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.rent {
  flex: 0 0 auto;
  color: #f97316;
  font-size: 34rpx;
  font-weight: 700;
}

.room-info {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.info-label {
  display: block;
  color: #6b7280;
  font-size: 22rpx;
}

.info-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.status-free {
  color: #16a34a;
}

.status-rented {
  color: #9ca3af;
}

.tags {
  margin-top: 12rpx;
}

.call-btn {
  height: 76rpx;
  margin-top: 24rpx;
  border-radius: 12rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 76rpx;
}
