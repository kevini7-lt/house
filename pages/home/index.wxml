<view class="page home-page">
  <banner-swiper list="{{banners}}" />

  <view class="search card">
    <text class="search-icon">搜</text>
    <input value="{{keyword}}" bindinput="onSearchInput" bindconfirm="goSearch" placeholder="搜索小区、区域或地址" confirm-type="search" />
  </view>

  <view class="section-title">小区列表</view>

  <view wx:if="{{loading}}" class="empty">正在加载房源数据...</view>
  <view wx:elif="{{communities.length === 0}}" class="empty">暂无匹配小区</view>
  <view wx:else>
    <community-card
      wx:for="{{communities}}"
      wx:key="id"
      community="{{item}}"
      bindtap="goBuildings"
    />
  </view>
</view>
