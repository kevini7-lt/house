.admin-hero {
  padding: 34rpx 6rpx 24rpx;
}

.admin-title {
  font-size: 42rpx;
  font-weight: 700;
}

.admin-subtitle {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  min-height: 180rpx;
  padding: 28rpx;
}

.stat-num {
  color: #1677ff;
  font-size: 44rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.summary {
  margin-top: 24rpx;
  padding: 28rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 28rpx;
}

.summary-row:last-child {
  border-bottom: 0;
}
