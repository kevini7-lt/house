<view class="page">
  <view class="admin-hero">
    <view class="admin-title">管理员统计</view>
    <view class="admin-subtitle">房源、小区与出租状态总览</view>
  </view>

  <view wx:if="{{loading}}" class="empty">正在加载统计...</view>
  <view wx:else class="stats-grid">
    <view class="stat-card card">
      <view class="stat-num">{{communityCount}}</view>
      <view class="stat-label">小区数量</view>
    </view>
    <view class="stat-card card">
      <view class="stat-num">{{buildingCount}}</view>
      <view class="stat-label">楼栋数量</view>
    </view>
    <view class="stat-card card">
      <view class="stat-num">{{roomCount}}</view>
      <view class="stat-label">房间数量</view>
    </view>
    <view class="stat-card card">
      <view class="stat-num">{{rentedRate}}</view>
      <view class="stat-label">已租比例</view>
    </view>
  </view>

  <view class="summary card">
    <view class="summary-row">
      <text>可入住房间</text>
      <text>{{availableCount}} 间</text>
    </view>
    <view class="summary-row">
      <text>已租房间</text>
      <text>{{rentedCount}} 间</text>
    </view>
  </view>
</view>
