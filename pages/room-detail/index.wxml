<view class="page">
  <view class="page-container detail-page">
    <page-header
      title="{{pageTitle}}"
      subtitle="{{room ? room.address : 'Select a room'}}"
    />

    <view wx:if="{{loading}}" class="empty">Loading room...</view>
    <view wx:elif="{{room}}" class="detail-body">
      <view class="card gallery-card">
        <swiper class="gallery-swiper" indicator-dots autoplay circular>
          <block wx:for="{{imageList}}" wx:key="*this">
            <swiper-item>
              <image class="gallery-image" src="{{item}}" mode="aspectFill" />
            </swiper-item>
          </block>
        </swiper>
      </view>

      <view class="card info-card">
        <view class="info-row">
          <view class="info-label">Title</view>
          <view class="info-value">{{room.title || room.name || 'Room'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">Room No</view>
          <view class="info-value">{{room.number || 'N/A'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">Rent</view>
          <view class="info-value text-primary">{{formatRent(room.rent)}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">Layout</view>
          <view class="info-value">{{room.layout || 'N/A'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">Description</view>
          <view class="info-value">{{room.description || room.address || 'N/A'}}</view>
        </view>
      </view>

      <view class="card favorite-card">
        <button
          class="favorite-button {{favoriteActive ? 'favorite-button-active' : ''}}"
          bindtap="handleFavorite"
        >
          {{favoriteText}}
        </button>
      </view>

      <view class="card tag-card" wx:if="{{room.tags && room.tags.length}}">
        <view class="tag-title">Tags</view>
        <tag-list tags="{{room.tags}}" />
      </view>
    </view>
  </view>
</view>
