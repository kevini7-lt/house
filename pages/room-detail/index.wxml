<view class="page">
  <view class="page-container detail-page">
    <page-header
      title="{{pageTitle}}"
      subtitle="{{room ? room.address : '请先选择房间'}}"
    />

    <view wx:if="{{loading}}" class="empty">正在加载房间...</view>
    <view wx:elif="{{room}}" class="detail-body">
      <view class="card gallery-card">
        <swiper class="gallery-swiper" indicator-dots autoplay circular>
          <block wx:for="{{imageList}}" wx:key="*this">
            <swiper-item>
              <image class="gallery-image" src="{{item}}" mode="aspectFill" />
            </swiper-item>
          </block>
        </swiper>
      </view>

      <view class="card info-card">
        <view class="info-row">
          <view class="info-label">标题</view>
          <view class="info-value">{{room.title || room.name || 'Room'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">房号</view>
          <view class="info-value">{{room.number || '暂无'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">租金</view>
          <view class="info-value text-primary">{{formatRent(room.rent)}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">户型</view>
          <view class="info-value">{{room.layout || '暂无'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">描述</view>
          <view class="info-value">{{room.description || room.address || '暂无描述'}}</view>
        </view>
      </view>

      <view class="card tag-card" wx:if="{{room.tags && room.tags.length}}">
        <view class="tag-title">房源标签</view>
        <tag-list tags="{{room.tags}}" />
      </view>
    </view>
  </view>
</view>
