@import "/theme/theme.wxss";

.detail-page {
  padding-bottom: 36rpx;
}

.detail-body {
  margin-top: 24rpx;
}

.gallery-card,
.video-card,
.info-card,
.tag-card {
  margin-bottom: 24rpx;
}

.gallery-swiper {
  height: 420rpx;
}

.gallery-image {
  width: 100%;
  height: 420rpx;
}

.video-player {
  width: 100%;
  height: 420rpx;
  background: #000000;
}

.info-card {
  padding: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 18rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid #edf3fb;
}

.info-label {
  width: 140rpx;
  color: #64748b;
  font-size: 24rpx;
}

.info-value {
  flex: 1;
  text-align: right;
  color: #1f2d3d;
  font-size: 26rpx;
  line-height: 1.5;
}

.tag-card {
  padding: 24rpx;
}

.favorite-card {
  padding: 24rpx;
}

.tag-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.favorite-button {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #2f6fe4;
  border: 1rpx solid #dbe7fb;
  font-size: 28rpx;
  line-height: 88rpx;
}

.favorite-button-active {
  background: #f0f6ff;
  color: #1677ff;
  border-color: #cfe0fb;
}

.action-row {
  display: flex;
  justify-content: space-between;
}

.action-button {
  width: calc(50% - 8rpx);
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 88rpx;
}

.action-call {
  background: #2f6fe4;
  color: #ffffff;
}

.action-copy {
  background: #ffffff;
  color: #2f6fe4;
  border: 1rpx solid #dbe7fb;
}
