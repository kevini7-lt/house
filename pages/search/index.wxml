<view class="page">
  <view class="search-bar card">
    <input
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
      placeholder="搜索小区、楼栋、房间"
      confirm-type="search"
    />
  </view>

  <view wx:if="{{loading}}" class="empty">正在搜索...</view>
  <view wx:elif="{{keyword === ''}}" class="empty">请输入关键词开始搜索</view>
  <view wx:elif="{{results.length === 0}}" class="empty">暂无匹配结果</view>
  <view wx:else>
    <view
      class="result-card card"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="goResult"
      data-type="{{item.type}}"
      data-id="{{item.id}}"
      data-roomid="{{item.roomId}}"
      data-communityid="{{item.communityId}}"
    >
      <view class="result-row">
        <view class="result-cover-wrap">
          <image class="result-cover" src="{{item.cover}}" mode="aspectFill" />
        </view>
        <view class="result-body">
          <view class="result-type">{{item.typeLabel}}</view>
          <view class="result-title">{{item.title}}</view>
          <view class="result-subtitle">{{item.subtitle}}</view>
          <view class="result-price" wx:if="{{item.type === 'room'}}">¥{{item.rent || 0}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
