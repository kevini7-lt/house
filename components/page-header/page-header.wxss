@import "/theme/theme.wxss";

.header {
  padding: 28rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.header-main {
  flex: 1;
  min-width: 0;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2d3d;
  line-height: 1.3;
}

.header-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.header-action {
  margin-left: 24rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f0f6ff;
  color: #2f6fe4;
  font-size: 24rpx;
  line-height: 1;
}
