@import "/theme/theme.wxss";

.banner {
  height: 330rpx;
}

.banner-swiper {
  height: 330rpx;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 330rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(11, 28, 61, 0.08) 0%, rgba(11, 28, 61, 0.48) 100%);
}

.banner-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
}

.banner-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.banner-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1.5;
}
