@import "/theme/theme.wxss";

.community {
  display: flex;
  padding: 18rpx;
}

.community-cover {
  width: 178rpx;
  height: 178rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.community-body {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.community-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.community-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.community-badge {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #2f6fe4;
  font-size: 22rpx;
}

.community-meta {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}
