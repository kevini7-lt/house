@import "/theme/theme.wxss";

.building {
  display: flex;
  padding: 18rpx;
}

.building-cover {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.building-body {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.building-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.building-meta {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
}
