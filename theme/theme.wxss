/* 主题和通用 UI 基础样式。 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6f9ff 0%, #ffffff 100%);
}

.page-container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e7eef8;
  box-shadow: 0 10rpx 30rpx rgba(33, 72, 133, 0.06);
  overflow: hidden;
}

.card + .card {
  margin-top: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2d3d;
  line-height: 1.4;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.muted {
  color: #64748b;
}

.text-primary {
  color: #2f6fe4;
}

.text-success {
  color: #18a058;
}

.text-danger {
  color: #d14343;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f0f6ff;
  color: #2f6fe4;
  font-size: 22rpx;
  line-height: 1;
}

.tag + .tag {
  margin-left: 12rpx;
  margin-top: 12rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: -12rpx;
}

.btn-primary,
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #2f6fe4 0%, #4a8cff 100%);
  color: #ffffff;
}

.btn-ghost {
  background: #ffffff;
  color: #2f6fe4;
  border: 1rpx solid #dbe7fb;
}

.sticky-footer {
  position: sticky;
  bottom: 0;
  background: linear-gradient(180deg, rgba(245, 248, 252, 0) 0%, rgba(245, 248, 252, 0.96) 18%, #f5f8fc 100%);
  padding: 20rpx 0 0;
}
